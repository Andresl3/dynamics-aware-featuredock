   "source": [
    "dd = pd.read_json('RelaxDB_133x_22jan2025.json.zip')\n",
    "for col in dd.columns:\n",
    "    if isinstance(dd[col].iloc[0],list):\n",
    "        dd[col] = [np.asarray(x,dtype=float) for x in dd[col]]\n",
    "\n",
    "print(len(dd))"
   ]
  },
