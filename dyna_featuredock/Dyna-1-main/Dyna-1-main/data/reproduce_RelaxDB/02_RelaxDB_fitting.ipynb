   "source": [
    "tt= pd.read_json('RelaxDB_pre_fitting_02aug2025.json.zip')\n",
    "\n",
    "for col in tt.columns:\n",
    "    if isinstance(tt[col].iloc[0],list):\n",
    "        tt[col] = [np.asarray(x,dtype=float) for x in tt[col]]\n",
    "\n",
    "print(len(tt))"
   ]
  },
  {
